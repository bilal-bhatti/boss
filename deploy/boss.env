# boss configuration — installed at /etc/default/boss, read by the systemd
# unit via `EnvironmentFile=`. One KEY=value per line (systemd env-file syntax:
# no quoting needed, no inline comments after a value). Blank/unset keys fall
# back to boss's built-in defaults.

# MQTT broker. Use an IP if the container has no mDNS resolver (nss-mdns) and
# the broker is only known as `*.local`.
BOSS_MQTT_HOST=192.0.2.10
BOSS_MQTT_PORT=1883
# BOSS_MQTT_USER=
# BOSS_MQTT_PASS=

# Home Assistant discovery prefix (default: homeassistant).
# BOSS_DISCOVERY_PREFIX=homeassistant

# Persisted Matter commissioning state. Keep this under StateDirectory so it
# survives restarts/reboots; changing it loses the pairing.
BOSS_STATE_DIR=/var/lib/boss

# Log level (env_logger): error|warn|info|debug|trace.
RUST_LOG=info
